{
  "app": {
    "name": "lightweight-ai-automation-framework",
    "debug": true
  },
  "input": {
    "maxLength": 640000
  },
  "workflow": {
    "autoActivate": true
  },
  "output": {
    "maxLength": 640000
  },
  "llm": {
    "provider": "ollama",
    "baseUrl": "http://127.0.0.1:11434",
    "model": "gemma4:e4b",
    "timeoutMs": 120000,
    "maxInputChars": 20000,
    "maxOutputTokens": 4000,
    "apiKey": "",
    "isReasoningModel": true,
    "reasoningStripMode": "auto"
  },
  "sqlite": {
    "path": "./data/tasks.db"
  },
  "email": {
    "provider": "smtp",
    "smtp": {
      "name": "AI Automation Framework",
      "host": "<SMTP HOST>",
      "port": 465,
      "secure": true,
      "auth": {
        "user": "<USER>",
        "pass": "<PASS>"
      }
    },
    "imap": {
      "user": "<USER>",
      "password": "<PASS>",
      "host": "<IMAP HOST>",
      "port": 993,
      "tls": true
    }
  },
  "search_web": {
    "api_key": "<SEARCH API KEY>"
  }
}
